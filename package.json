{
  "name": "rephrame",
  "version": "1.0.0",
  "private": true,
  "description": "A private, offline-first CBT journal (static PWA). This manifest exists only to pin the smoke-test toolchain and let Dependabot track it.",
  "type": "module",
  "scripts": {
    "serve": "python3 -m http.server 8765",
    "lint": "eslint .",
    "check": "node tests/check-static.mjs",
    "test": "node tests/smoke.mjs",
    "flows": "node tests/flows.mjs",
    "robustness": "node tests/robustness.mjs",
    "sync": "node tests/sync.mjs"
  },
  "devDependencies": {
    "eslint": "^10.5.0",
    "playwright": "1.61.0"
  }
}
